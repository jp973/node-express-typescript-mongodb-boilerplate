#!/bin/sh
set -e

#######################################
# Helper: detect OS
#######################################
OS="$(uname -s)"

is_windows() {
  echo "$OS" | grep -qi "mingw\|msys\|cygwin"
}

#######################################
# GITLEAKS (STAGED ONLY)
#######################################

echo "🔍 Running Gitleaks pre-commit scan..."

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "⚠️ Gitleaks not found. Installing..."

  if [ "$OS" = "Darwin" ]; then
    brew install gitleaks

  elif [ "$OS" = "Linux" ]; then
    curl -sSfL https://raw.githubusercontent.com/gitleaks/gitleaks/master/install.sh | sh
    export PATH="$PATH:$HOME/.local/bin"

  elif is_windows; then
    echo "❌ Auto-install not supported on Windows (Git Bash)."
    echo "👉 Install manually:"
    echo "   winget install Gitleaks.Gitleaks"
    echo "   OR choco install gitleaks"
    exit 1

  else
    echo "❌ Unsupported OS: $OS"
    exit 1
  fi
fi

gitleaks git --redact
echo "✅ Gitleaks scan passed"

#######################################
# SEMGREP (STAGED JS/TS ONLY)
#######################################

echo "🔍 Running Semgrep pre-commit scan..."

if ! command -v semgrep >/dev/null 2>&1; then
  echo "⚠️ Semgrep not found. Installing..."

  if [ "$OS" = "Darwin" ]; then
    brew install semgrep

  elif [ "$OS" = "Linux" ]; then
    curl -sSfL https://install.semgrep.dev | sh
    export PATH="$PATH:$HOME/.local/bin"

  elif is_windows; then
    echo "❌ Auto-install not supported on Windows (Git Bash)."
    echo "👉 Install manually:"
    echo "   winget install Semgrep.Semgrep"
    echo "   OR choco install semgrep"
    exit 1

  else
    echo "❌ Unsupported OS: $OS"
    exit 1
  fi
fi

FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(js|ts|jsx|tsx)$' || true)

if [ -n "$FILES" ]; then
export PYTHONUTF8=1
  # shellcheck disable=SC2086
  semgrep --config=auto --error $FILES
  echo "✅ Semgrep scan passed"
else
  echo "ℹ️ No JS/TS files staged. Skipping Semgrep."
fi

#######################################
# TRIVY (DEPENDENCY FILES ONLY)
#######################################

echo "🔍 Running Trivy pre-commit scan..."

STAGED_FILES=$(git diff --cached --name-only)

if ! echo "$STAGED_FILES" | grep -Eq '(package\.json|package-lock\.json|pnpm-lock\.yaml|yarn\.lock)'; then
  echo "ℹ️ No dependency changes staged. Skipping Trivy."
else
  if ! command -v trivy >/dev/null 2>&1; then
    echo "⚠️ Trivy not found. Installing..."

    if [ "$OS" = "Darwin" ]; then
      brew install trivy

    elif [ "$OS" = "Linux" ]; then
      curl -sSfL https://raw.githubusercontent.com/aquasecurity/trivy/main/contrib/install.sh | sh
      export PATH="$PATH:$HOME/.local/bin"

    elif is_windows; then
      echo "❌ Auto-install not supported on Windows (Git Bash)."
      echo "👉 Install manually:"
      echo "   winget install AquaSecurity.Trivy"
      echo "   OR choco install trivy"
      exit 1

    else
      echo "❌ Unsupported OS: $OS"
      exit 1
    fi
  fi

  # Extract directories from .gitignore
  SKIP_DIRS=$(grep -vE '^\s*#|^\s*$' .gitignore \
    | grep -vE '^[!]|[*]' \
    | grep -E '/$' \
    | sed 's#^/##; s#/$##' \
    | tr '\n' ',')

  SKIP_DIRS="node_modules,${SKIP_DIRS}"
  SKIP_DIRS=$(echo "$SKIP_DIRS" | sed 's/,$//')

  echo "ℹ️ Trivy skip-dirs: $SKIP_DIRS"

  trivy fs . \
    --scanners vuln \
    --skip-dirs "$SKIP_DIRS" \
    --severity HIGH,CRITICAL \
    --exit-code 1

  echo "✅ Trivy scan passed"
fi

#######################################
# BUILD (FINAL GATE)
#######################################

echo "🔍 Running build..."
npm run build
echo "✅ Build passed"
